<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Rounded pill -->
    <corners android:radius="30dp"/>

    <!-- Soft background (NOT strong gold) -->
    <solid android:color="#EFE6DC"/>

    <!-- Gold border -->
    <stroke
        android:width="2dp"
        android:color="#D6B25E"/>

    <!-- Padding inside -->
    <padding
        android:left="10dp"
        android:right="10dp"
        android:top="6dp"
        android:bottom="6dp"/>

</shape>