<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft outer glow instead of dark shadow -->
    <item>
        <shape>
            <solid android:color="#10D6B25E"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Main card -->
    <item android:top="1dp">
        <shape>
            <gradient
                android:startColor="#F7F2EC"
                android:endColor="#EEE5DB"
                android:angle="90"/>

            <stroke
                android:width="1dp"
                android:color="#D6B25E"/>

            <corners android:radius="24dp"/>
        </shape>
    </item>

</layer-list>