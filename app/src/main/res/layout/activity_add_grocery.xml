<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EEE9">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Item"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#3A2A0A"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add a new grocery item to your pantry"
                android:textSize="14sp"
                android:textColor="#6B5B3E"
                android:layout_marginBottom="18dp"/>

            <!-- MODE TOGGLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_toggle_track"
                android:padding="4dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBranded"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Branded"
                    android:background="@drawable/bg_toggle_selected_soft"
                    android:backgroundTint="@null"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLoose"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Loose"
                    android:background="@android:color/transparent"
                    android:backgroundTint="@null"/>
            </LinearLayout>

            <!-- MAIN CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp"
                app:strokeWidth="2dp"
                app:strokeColor="#D6B25E"
                android:backgroundTint="#F8EFEA">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- ITEM NAME -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item Name"
                        android:textColor="#3A2A0A"/>

                    <EditText
                        android:id="@+id/editTextName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_soft"
                        android:hint="Milk, Rice..."/>

                    <!-- QUANTITY -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Quantity"
                        android:textColor="#3A2A0A"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <!-- COUNTER -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_soft"
                            android:orientation="horizontal"
                            android:padding="4dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/btnMinus"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="-"
                                android:background="@drawable/bg_capsule_outline"/>

                            <TextView
                                android:id="@+id/textQuantity"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="1"/>

                            <TextView
                                android:id="@+id/btnPlus"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="+"
                                android:background="@drawable/bg_capsule_outline"/>
                        </LinearLayout>

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="match_parent"/>

                        <!-- UNIT -->
                        <Spinner
                            android:id="@+id/spinnerUnit"
                            android:layout_width="120dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_input_soft"/>
                    </LinearLayout>

                    <!-- CATEGORY -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Category"
                        android:textColor="#3A2A0A"/>

                    <Spinner
                        android:id="@+id/spinnerCategory"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_soft"/>

                    <!-- BARCODE -->

                    <LinearLayout
                        android:id="@+id/layoutBarcode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <!-- LABEL -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Barcode"
                            android:textColor="#3A2A0A"/>

                        <!-- FIELD ROW -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/editTextBarcode"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/bg_input_soft"
                                android:hint="Enter barcode"/>

                            <Space
                                android:layout_width="8dp"
                                android:layout_height="match_parent"/>

                            <Button
                                android:id="@+id/buttonScan"
                                android:layout_width="90dp"
                                android:layout_height="match_parent"
                                android:text="Scan"
                                android:background="@drawable/bg_capsule_bronze"
                                android:textColor="#2E1A0C"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- EXPIRY -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Expiry Date"
                        android:textColor="#3A2A0A"/>

                    <EditText
                        android:id="@+id/editTextExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_soft"
                        android:hint="Select Date"
                        android:focusable="false"/>

                    <!-- NOTES -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Notes (Optional)"
                        android:textColor="#3A2A0A"/>

                    <EditText
                        android:id="@+id/editTextNotes"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_soft"
                        android:hint="Add details..."/>

                    <!-- ADD BUTTON -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/buttonSave"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="@android:color/transparent">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_capsule_bronze">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="+ Add Item"
                                android:textColor="#2E1A0C"
                                android:textStyle="bold"/>
                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- CANCEL -->
                    <Button
                        android:id="@+id/buttonCancel"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_capsule_outline"
                        android:text="Cancel"
                        android:textColor="#8E6B2F"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>