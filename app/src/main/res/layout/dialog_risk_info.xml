<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8F2EC">

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waste Risk Formula"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#4A3B35"/>

    <!-- FORMULA -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Risk = (Expiry × 0.6) + (Stock × 0.3) + (Urgency × 0.1)"
        android:textColor="#6D5C54"
        android:layout_marginTop="10dp"/>

    <!-- SECTION -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expiry Risk"
        android:textStyle="bold"
        android:textColor="#4A3B35"
        android:layout_marginTop="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=">7 days → Low\n3–7 days → Medium\n1–2 days → High\nExpired → Critical"
        android:textColor="#6D5C54"/>

    <!-- SECTION -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stock Pressure"
        android:textStyle="bold"
        android:textColor="#4A3B35"
        android:layout_marginTop="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="(Quantity / (Days + 1)) × 20"
        android:textColor="#6D5C54"/>

    <!-- SECTION -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Urgency Boost"
        android:textStyle="bold"
        android:textColor="#4A3B35"
        android:layout_marginTop="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Expired → +20\nLast day → +10"
        android:textColor="#6D5C54"/>

</LinearLayout>