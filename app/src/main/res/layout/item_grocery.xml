<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:id="@+id/card_root_container"
    app:cardBackgroundColor="#161620"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Expiring Badge -->
        <TextView
            android:id="@+id/text_expiring_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ EXPIRING SOON"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="6dp"/>

        <!-- Item Name -->
        <TextView
            android:id="@+id/text_view_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name"
            android:textColor="#F6F6F8"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <!-- Quantity -->
        <TextView
            android:id="@+id/text_view_quantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qty: 0"
            android:textColor="#D0D0D8"
            android:textSize="15sp"
            android:layout_marginTop="4dp"/>

        <!-- Category -->
        <TextView
            android:id="@+id/text_view_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="#C9B6EF"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

        <!-- Expiry -->
        <TextView
            android:id="@+id/text_view_expiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expiry:"
            android:textColor="#F6F6F8"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

        <!-- DAYS LEFT -->
        <TextView
            android:id="@+id/text_days_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 days left"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>

        <!-- Expiry Status Icon -->
        <ImageView
            android:id="@+id/image_expiry_status"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="6dp"
            android:contentDescription="Expiry status indicator"/>

        <!-- Risk Label -->
        <TextView
            android:id="@+id/text_view_risk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk: LOW"
            android:textColor="#F6F6F8"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>