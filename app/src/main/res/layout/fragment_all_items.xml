<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EEE9">

    <!-- SCROLLABLE CONTAINER -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- App Title -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PantryPal"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#3A2A0A"/>

                    <TextView
                        android:id="@+id/tvSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Pantry Dashboard"
                        android:textSize="16sp"
                        android:textColor="#6B5B3E"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvTagline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart grocery tracking &amp; analytics"
                        android:textSize="12sp"
                        android:textColor="#9C8B6E"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Profile Avatar -->
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_profile_circle"
                    android:padding="6dp"
                    android:src="@drawable/ic_profile"
                    android:scaleType="centerCrop"/>

            </RelativeLayout>

            <!-- ================= TOP CARDS ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <!-- TOTAL ITEMS CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#D6B25E"
                    android:backgroundTint="#F8EFEA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Items"
                            android:textColor="#7B6C65"/>

                        <TextView
                            android:id="@+id/text_total_items"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- EXPIRING CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#D6B25E"
                    android:backgroundTint="#F8EFEA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expiring"
                            android:textColor="#7B6C65"/>

                        <TextView
                            android:id="@+id/text_expiring_items"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ================= DASHBOARD ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- WASTE RISK -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#D6B25E"
                    android:backgroundTint="#F8EFEA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <!-- TITLE + INFO -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/tvWasteRiskTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Waste Risk"
                                android:textColor="#7B6C65"/>

                            <ImageView
                                android:id="@+id/btnWasteInfo"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_alignParentEnd="true"
                                android:padding="7dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@drawable/ic_info"
                                app:tint="#C2A24F"/>
                        </RelativeLayout>

                        <com.example.pantrypal.ui.CustomGaugeView
                            android:id="@+id/customGauge"
                            android:layout_width="140dp"
                            android:layout_height="100dp"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:id="@+id/text_risk_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <!-- CATEGORY -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#D6B25E"
                    android:backgroundTint="#F8EFEA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- TITLE + INFO -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/tvCategoryTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Category"
                                android:textColor="#7B6C65"/>

                            <ImageView
                                android:id="@+id/btnCategoryInfo"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_alignParentEnd="true"
                                android:padding="7dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@drawable/ic_info"
                                app:tint="#C2A24F"/>
                        </RelativeLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginTop="10dp"
                            android:layout_gravity="center">

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/categoryChart"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>
                        </FrameLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ================= QUICK ADD ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="#D6B25E"
                android:backgroundTint="#F8EFEA">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/btn_add_item"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:gravity="center"
                        android:text="+ Quick Add Item"
                        android:textColor="#3A2A0A"
                        android:background="@drawable/bg_toggle_selected_pearl"
                        android:elevation="4dp"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= ANALYTICS ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="2dp"
                app:strokeColor="#D6B25E"
                android:backgroundTint="#F8EFEA">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analytics Preview"
                        android:textSize="18sp"
                        android:textColor="#4A3B35"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- BAR -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="180dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="16dp"
                            android:backgroundTint="#FFFFFF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Expiry Risk Distribution"
                                    android:textSize="12sp"
                                    android:textColor="#333"/>

                                <com.github.mikephil.charting.charts.BarChart
                                    android:id="@+id/barChartExpiry"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- LINE -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="180dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="16dp"
                            android:backgroundTint="#FFFFFF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Monthly Consumption Trend"
                                    android:textSize="12sp"
                                    android:textColor="#333"/>

                                <com.github.mikephil.charting.charts.LineChart
                                    android:id="@+id/lineChartTrend"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Analytics →"
                        android:textColor="#8E6B2F"
                        android:layout_gravity="end"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>
